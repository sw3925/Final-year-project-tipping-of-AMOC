ax2.set_ylabel("$s_N$")
ax2.set_title("$s_N$")

ax3.set_xlabel("$s_L$")
ax3.set_ylabel("$s_N$")
ax3.set_xbound(0.96,1.02)
ax3.set_ybound(0.96,1.02)
